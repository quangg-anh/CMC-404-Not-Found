# Admin portal -> BE3 API base URL.
# Defaults to http://localhost:8000 when unset (see src/lib/api.ts).
# Copy to `.env` and change only if the backend runs elsewhere.
VITE_API_URL=http://localhost:8000
# Router/asset base. Use `/` on Railway (app at domain root). Use `/admin` only for path-prefix hosting.
# VITE_BASE_PATH=/
# Optional: redirect non-admin login to the citizen deploy URL
# VITE_CITIZEN_URL=https://your-citizen.up.railway.app
