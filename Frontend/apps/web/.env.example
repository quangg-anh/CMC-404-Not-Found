# Admin portal -> BE3 API base URL (baked into the JS bundle at BUILD time).
#
# Local:
#   VITE_API_URL=http://localhost:8000
#
# Railway (REQUIRED — otherwise browser calls localhost → "Failed to fetch"):
#   1. Backend public HTTPS URL (Settings → Networking), e.g. https://api-xxxx.up.railway.app
#   2. Admin Frontend Variables: VITE_API_URL=https://api-xxxx.up.railway.app
#   3. Redeploy Admin Frontend after changing VITE_*
#   4. Backend: CORS_ALLOW_ALL=true
#
# Optional: redirect non-admin login to the citizen deploy URL
# VITE_CITIZEN_URL=https://citizen-xxxx.up.railway.app
VITE_API_URL=http://localhost:8000
# VITE_BASE_PATH=/
