# Unified LexSocial web app (citizen `/` + admin `/admin`) → BE3 API.
# Baked into the JS bundle at BUILD time — Redeploy after changing VITE_*.
#
# Local:
#   VITE_API_URL=http://localhost:8000
#
# Railway:
#   VITE_API_URL=https://<backend-public>.up.railway.app
#   Backend: CORS_ALLOW_ALL=true
VITE_API_URL=http://localhost:8000
# Optional reverse-proxy prefix (usually leave as /)
# VITE_BASE_PATH=/
