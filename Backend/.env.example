# =========================================================
# BE2 Social Monitor - biến môi trường mẫu
# Copy file này sang Backend/.env hoặc set env vars trong máy/CI.
# KHÔNG commit token/API key thật.
# =========================================================

# ── App Environment & Security ──────────────────────────
# APP_ENV: "development" | "test" | "local" | "staging" | "production"
# In production/staging: AUTH_TOKEN_SECRET is REQUIRED (min 32 chars, no weak patterns).
# Dev tokens are FORBIDDEN in production/staging regardless of ENABLE_DEV_TOKENS.
APP_ENV=development
AUTH_TOKEN_SECRET=change_me_generate_a_random_string_at_least_32_chars
ENABLE_DEV_TOKENS=false
# Allow FE on any domain (Railway / custom host). Set false + CORS_EXTRA_ORIGINS to lock down.
CORS_ALLOW_ALL=true
# CORS_EXTRA_ORIGINS=https://admin.example.com,https://citizen.example.com

# Parser LLM fallback for non-standard legal documents
PARSER_LLM_FALLBACK_ENABLED=true
PARSER_LLM_FALLBACK_THRESHOLD=0.75
PARSER_LLM_FALLBACK_TIMEOUT_SECONDS=30
PARSER_LLM_FALLBACK_MAX_INPUT_CHARS=120000

# Bật dump trích dẫn thô khi LLM lỗi (KHÔNG khuyến nghị — dễ lệch chủ đề). Mặc định tắt.
QA_EXTRACTIVE_FALLBACK=0

# ── BE2 Intelligence service (LLM gateway used by QA / briefs) ──
# Local: start with `uvicorn be2_service:app --port 8002` (or ./run.ps1 — opens BE2 + BE3).
# Local default: http://localhost:8002
# Railway private: MUST include scheme, e.g.
#   BE2_INTELLIGENCE_URL=http://${{be2.RAILWAY_PRIVATE_DOMAIN}}:8002
# Without http:// httpx fails: "Request URL is missing an 'http://' or 'https://' protocol"
# Alias (optional): BE2_LLM_GATEWAY_URL — same value; config falls back to it if this is unset.
BE2_INTELLIGENCE_URL=http://localhost:8002

# Bật/tắt job theo dõi MXH hằng ngày
BE2_SOCIAL_MONITOR_ENABLED=true

# Chủ đề pháp luật cần theo dõi, phân tách bằng dấu phẩy.
# Nên viết cụm từ cụ thể thay vì từ đơn để prompt/search bám đúng ngữ cảnh.
BE2_SOCIAL_MONITOR_TOPICS=thuế giá trị gia tăng,thuế thu nhập cá nhân,thuế thu nhập doanh nghiệp,hóa đơn điện tử,kê khai thuế,quyết toán thuế,hoàn thuế,nợ thuế,xử phạt vi phạm thuế,tài chính doanh nghiệp,báo cáo tài chính,ngân sách nhà nước,phí và lệ phí,quản lý giá,đấu thầu,mua sắm công,kinh doanh thương mại,đăng ký kinh doanh,điều kiện kinh doanh,hợp đồng thương mại,thương mại điện tử,bảo vệ người tiêu dùng,cạnh tranh,khuyến mại,quảng cáo,nhượng quyền thương mại,xuất nhập khẩu,hải quan

# Số bài tối đa mỗi topic/source
BE2_SOCIAL_MONITOR_LIMIT_PER_TOPIC=10

# Khoảng thời gian nhìn lại khi collect
BE2_SOCIAL_MONITOR_LOOKBACK_HOURS=24

# Lịch chạy daily cron theo giờ server
BE2_SOCIAL_MONITOR_CRON_HOUR=17
BE2_SOCIAL_MONITOR_CRON_MINUTE=0

# Lịch tự động lấy tin pháp luật từ https://phapluat.gov.vn/tin-tuc
# Chủ đề lọc cố định: thuế, tài chính, kinh doanh thương mại
BE2_NEWS_BRIEF_ENABLED=true
BE2_NEWS_BRIEF_CRON_HOUR=7
BE2_NEWS_BRIEF_CRON_MINUTE=0
BE2_NEWS_BRIEF_LIMIT_PER_TOPIC=5

# News-first misconception monitor. Enable after the gold-set acceptance gate passes.
BE2_NEWS_MONITOR_ENABLED=false
BE2_NEWS_MONITOR_CRON_HOUR=7
BE2_NEWS_MONITOR_CRON_MINUTE=15
BE2_NEWS_MONITOR_LIMIT_PER_TOPIC=5

# LAWGIC core v2 — additive rollout, keep reads/commit disabled until acceptance gates pass.
LEGAL_PROVISION_V2_WRITE=false
LEGAL_PROVISION_V2_READ=false
TEMPORAL_LAW_V2=false
QA_CITATION_V2=false
QA_STRICT_GROUNDING_V2=true
AMENDMENT_PREVIEW_V2=false
AMENDMENT_COMMIT_V2=false
MISCONCEPTION_TEMPORAL_V2=false

# Facebook Graph API
BE2_FACEBOOK_ACCESS_TOKEN=change_me_facebook_access_token
BE2_FACEBOOK_PAGE_IDS=change_me_page_id_1,change_me_page_id_2
BE2_FACEBOOK_API_VERSION=v20.0

# YouTube Data API
BE2_YOUTUBE_API_KEY=change_me_youtube_api_key
BE2_YOUTUBE_API_KEYS=change_me_youtube_api_key_1,change_me_youtube_api_key_2,change_me_youtube_api_key_3
BE2_YOUTUBE_CHANNEL_IDS=
BE2_YOUTUBE_SEARCH_ORDER=relevance
BE2_YOUTUBE_SEARCH_RESULTS_PER_TOPIC=25
BE2_YOUTUBE_REGION_CODE=VN
BE2_YOUTUBE_RELEVANCE_LANGUAGE=vi
BE2_YOUTUBE_FILTER_VIETNAMESE=true
BE2_YOUTUBE_COMMENTS_ENABLED=true
BE2_YOUTUBE_COMMENTS_PER_VIDEO=50
BE2_YOUTUBE_COMMENTS_PER_TOPIC=50
BE2_YOUTUBE_COMMENTS_AS_POSTS=true
BE2_YOUTUBE_MIN_COMMENT_LENGTH=12
BE2_YOUTUBE_SKIP_COMMENT_URLS=true
BE2_YOUTUBE_SKIP_VIDEOS_WITHOUT_COMMENTS=true
BE2_YOUTUBE_REQUIRE_TOPIC_IN_COMMENTS=true

# RSS/Atom forum feeds công khai, nếu có
BE2_FORUM_FEED_URLS=https://example.com/rss,https://example.com/atom

# Redis cho worker (Railway sets REDIS_URL automatically via reference variables;
# REDIS_URL takes precedence over BE2_REDIS_URL when both are set)
REDIS_URL=redis://localhost:6379/0
BE2_REDIS_URL=redis://localhost:6379/0

# Secret hash tác giả social ingest
BE2_AUTHOR_HMAC_SECRET=change_me_long_random_secret

# =========================================================
# AI API — OpenAI-compatible ONLY (no Ollama)
# Copy sang Backend/.env rồi điền token thật. KHÔNG commit token thật.
# =========================================================

# Shared OpenAI-compatible host
BE2_LLM_BACKEND=openai
BE2_OPENAI_BASE_URL=https://9router.wangganh.id.vn/v1
BE2_OPENAI_API_KEY=change_me_9router_api_key

# --- 2 chat models ---
# LOCAL  = parse/extract nhẹ  → POST BE2 /local
# LARGE  = QA / brief / NER   → POST BE2 /large
BE2_LLM_LOCAL_MODEL=mimax
BE2_LLM_LARGE_MODEL=mimax
BE2_LLM_TIMEOUT_S=40
BE2_LLM_LOCAL_TIMEOUT_S=30
BE2_LLM_LARGE_TIMEOUT_S=40
BE2_LLM_TEMPERATURE=0.15
BE2_LLM_MAX_TOKENS=480
# Độ dài mỗi khoản đưa vào prompt (ký tự) — cân bằng tốc độ/độ chi tiết
BE2_LLM_CTX_CHARS=400
BE2_LLM_REPEAT_PENALTY=1.15
# QA response cache (Redis). Set 0 / false to disable.
BE2_QA_CACHE_ENABLED=true
BE2_QA_CACHE_TTL_S=300
# Optional real NLI (transformers). Default uses improved heuristic + numeric checks.
# BE2_NLI_TRANSFORMERS=1
# BE2_NLI_MODEL=MoritzLaurer/mDeBERTa-v3-base-mnli-xnli

# --- 1 embedding model ---
# Defaults to BE2_OPENAI_BASE_URL / BE2_OPENAI_API_KEY if unset.
BE2_EMBEDDING_PROVIDER=openai
BE2_EMBEDDING_BASE_URL=https://9router.wangganh.id.vn/v1
BE2_EMBEDDING_API_KEY=change_me_9router_api_key
BE2_EMBEDDING_MODEL=text-embedding-3-small
BE2_EMBEDDING_DIMENSION=1536
BE2_EMBEDDING_TIMEOUT_S=60
# MUST be an embedding model id — chat models (mistral/grok/…) cause HTTP 400 on /embeddings.
# If DIMENSION changes, recreate Qdrant collections and reindex.
