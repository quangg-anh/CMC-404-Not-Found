# =========================================================
# BE2 Social Monitor - biến môi trường mẫu
# Copy file này sang Backend/.env hoặc set env vars trong máy/CI.
# KHÔNG commit token/API key thật.
# =========================================================

# Bật/tắt job theo dõi MXH hằng ngày
BE2_SOCIAL_MONITOR_ENABLED=true

# Chủ đề pháp luật cần theo dõi, phân tách bằng dấu phẩy.
# Nên viết cụm từ cụ thể thay vì từ đơn để prompt/search bám đúng ngữ cảnh.
BE2_SOCIAL_MONITOR_TOPICS=thuế giá trị gia tăng,thuế thu nhập cá nhân,thuế thu nhập doanh nghiệp,hóa đơn điện tử,kê khai thuế,quyết toán thuế,hoàn thuế,nợ thuế,xử phạt vi phạm thuế,tài chính doanh nghiệp,báo cáo tài chính,ngân sách nhà nước,phí và lệ phí,quản lý giá,đấu thầu,mua sắm công,kinh doanh thương mại,đăng ký kinh doanh,điều kiện kinh doanh,hợp đồng thương mại,thương mại điện tử,bảo vệ người tiêu dùng,cạnh tranh,khuyến mại,quảng cáo,nhượng quyền thương mại,xuất nhập khẩu,hải quan

# Số bài tối đa mỗi topic/source
BE2_SOCIAL_MONITOR_LIMIT_PER_TOPIC=10

# Khoảng thời gian nhìn lại khi collect
BE2_SOCIAL_MONITOR_LOOKBACK_HOURS=24

# Lịch chạy daily cron theo giờ server
BE2_SOCIAL_MONITOR_CRON_HOUR=17
BE2_SOCIAL_MONITOR_CRON_MINUTE=0

# Lịch tự động lấy tin pháp luật từ https://phapluat.gov.vn/tin-tuc
# Chủ đề lọc cố định: thuế, tài chính, kinh doanh thương mại
BE2_NEWS_BRIEF_ENABLED=true
BE2_NEWS_BRIEF_CRON_HOUR=7
BE2_NEWS_BRIEF_CRON_MINUTE=0
BE2_NEWS_BRIEF_LIMIT_PER_TOPIC=5

# Facebook Graph API
BE2_FACEBOOK_ACCESS_TOKEN=change_me_facebook_access_token
BE2_FACEBOOK_PAGE_IDS=change_me_page_id_1,change_me_page_id_2
BE2_FACEBOOK_API_VERSION=v20.0

# YouTube Data API
BE2_YOUTUBE_API_KEY=change_me_youtube_api_key
BE2_YOUTUBE_API_KEYS=change_me_youtube_api_key_1,change_me_youtube_api_key_2,change_me_youtube_api_key_3
BE2_YOUTUBE_CHANNEL_IDS=
BE2_YOUTUBE_SEARCH_ORDER=relevance
BE2_YOUTUBE_SEARCH_RESULTS_PER_TOPIC=25
BE2_YOUTUBE_REGION_CODE=VN
BE2_YOUTUBE_RELEVANCE_LANGUAGE=vi
BE2_YOUTUBE_FILTER_VIETNAMESE=true
BE2_YOUTUBE_COMMENTS_ENABLED=true
BE2_YOUTUBE_COMMENTS_PER_VIDEO=50
BE2_YOUTUBE_COMMENTS_PER_TOPIC=50
BE2_YOUTUBE_COMMENTS_AS_POSTS=true
BE2_YOUTUBE_MIN_COMMENT_LENGTH=12
BE2_YOUTUBE_SKIP_COMMENT_URLS=true
BE2_YOUTUBE_SKIP_VIDEOS_WITHOUT_COMMENTS=true
BE2_YOUTUBE_REQUIRE_TOPIC_IN_COMMENTS=true

# RSS/Atom forum feeds công khai, nếu có
BE2_FORUM_FEED_URLS=https://example.com/rss,https://example.com/atom

# Redis cho worker
BE2_REDIS_URL=redis://localhost:6379/0

# Secret hash tác giả social ingest
BE2_AUTHOR_HMAC_SECRET=change_me_long_random_secret

# =========================================================
# AI API / LLM qua 9router (OpenAI-compatible)
# Copy sang Backend/.env rồi điền token thật. KHÔNG commit token thật.
# =========================================================

# Dùng 9router thay Ollama/local model
BE2_LLM_BACKEND=openai

# Base URL 9router OpenAI-compatible
BE2_OPENAI_BASE_URL=https://9router.wangganh.id.vn/v1

# Model 9router cần dùng
BE2_OPENAI_MODEL=mimax

# Token API 9router thật, điền trong Backend/.env
BE2_OPENAI_API_KEY=change_me_9router_api_key

# Tuỳ chỉnh sinh câu trả lời
BE2_LLM_TIMEOUT_S=90
BE2_LLM_TEMPERATURE=0.2
BE2_LLM_MAX_TOKENS=1024
BE2_LLM_REPEAT_PENALTY=1.3
