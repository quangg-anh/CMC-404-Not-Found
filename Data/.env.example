# =========================================================
# Data Platform - biến môi trường mẫu (KHÔNG commit secret thật)
# Copy sang .env rồi chỉnh giá trị:  cp .env.example .env
# =========================================================

# ---------- Neo4j ----------
NEO4J_AUTH=neo4j/change_me_neo4j
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
# Bolt URI cho backend: bolt://<host>:7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_neo4j

# ---------- PostgreSQL ----------
POSTGRES_USER=app_be_rw
POSTGRES_PASSWORD=change_me_pg
POSTGRES_DB=legal_kg
POSTGRES_PORT=5432
# DSN cho backend: postgresql://app_be_rw:<pw>@localhost:5432/legal_kg
DATABASE_URL=postgresql://app_be_rw:change_me_pg@localhost:5432/legal_kg

# ---------- Qdrant ----------
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://localhost:6333
# Dim vector mặc định (text-embedding-3-small = 1536). Khớp BE2_EMBEDDING_DIMENSION.
# Nếu đổi dim: recreate Qdrant collections rồi reindex.
EMBEDDING_DIM=1536

# ---------- Redis ----------
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# ---------- MinIO (S3-compatible) ----------
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=change_me_minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET_LEGAL=legal-raw
MINIO_BUCKET_SOCIAL=social-raw
